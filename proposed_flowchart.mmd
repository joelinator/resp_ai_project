flowchart TB
    S([Start])

    subgraph INIT[Initialization]
        direction LR
        I1[Load processed ASSISTments data]
        I2[Build KT features and train calibrated model]
        I3[Initialize LinUCB parameters]
        I4[Initialize fairness penalties by gender]
        I1 --> I2 --> I3 --> I4
    end

    subgraph LOOP[Per-interaction online loop]
        direction LR
        C1[Build context]
        C2[LinUCB selects action A/B/C]
        C3[Execute selected action]
        C4[Compute loss<br/>loss = 1 if wrong else 0]
        C5[Apply action cost]
        U1[Reward = - total cost]
        U2[Update LinUCB]
        L1[Log action/loss/cost/fairness]
        G0{step mod 500 == 0?}
        N{More interactions?}

        C1 --> C2 --> C3 --> C4 --> C5 --> U1 --> U2 --> L1 --> G0
        G0 -- No --> N
    end

    subgraph GUARD[Fairness guardrail every 500 interactions]
        direction LR
        G1[Compute FNR_male and FNR_female]
        G2[Delta_EO = abs(FNR_male - FNR_female)]
        G3{Delta_EO > 0.05?}
        G4[Increase AI penalty for disadvantaged gender]
        G5[Keep penalties unchanged]

        G1 --> G2 --> G3
        G3 -- Yes --> G4
        G3 -- No --> G5
    end

    OUT[Outputs:<br/>coverage, escalation, diagnostic rate,<br/>average loss, average total cost,<br/>fairness metrics, guardrail history,<br/>risk-coverage plots, SHAP artifacts]
    subgraph LEGEND[Action legend]
        direction LR
        LGA[A = AI Answers]
        LGB[B = Escalate to Human]
        LGC[C = Request Diagnostic]
        LCA[Cost A = loss + 0.0]
        LCB[Cost B = loss + 0.8]
        LCC[Cost C = loss + 0.4]
    end

    E([End])

    S --> INIT --> C1
    G0 -- Yes --> G1
    G4 --> N
    G5 --> N
    N -- Yes --> C1
    N -- No --> OUT --> E

    OUT -. legend .-> LGA
