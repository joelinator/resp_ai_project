flowchart TB
    S([Start guardrail monitor])
    E([End])

    subgraph WINDOW[Every 500 interactions]
        direction LR
        W1[Read recent policy logs]
        W2[Compute FNR_male]
        W3[Compute FNR_female]
        W4[Delta_EO = abs(FNR_male - FNR_female)]
        D{Delta_EO > 0.05?}
        U1[Increase AI penalty<br/>for disadvantaged gender]
        U2[Keep penalties unchanged]
        W1 --> W2 --> W3 --> W4 --> D
        D -- Yes --> U1
        D -- No --> U2
    end

    subgraph EFFECT[Effect on next window]
        direction LR
        E1[Updated penalty affects<br/>LinUCB action scores]
        E2[Policy shifts autonomy/escalation mix]
        E3[Log fairness history + penalties]
        E1 --> E2 --> E3
    end

    subgraph LEGEND[Legend]
        direction LR
        L1[Action A: AI]
        L2[Action B: Human]
        L3[Action C: Diagnostic]
        L4[Cost A = loss + 0.0]
        L5[Cost B = loss + 0.8]
        L6[Cost C = loss + 0.4]
        L7[loss = 1 if wrong else 0]
    end

    S --> WINDOW
    U1 --> E1
    U2 --> E1
    E3 --> E
